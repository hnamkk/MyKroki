# API key is optional when GitHub OIDC is enabled. Never store plaintext keys here.
# Run `npm run key:generate --prefix .. -- local-admin` to create a verifier record.
DIAGRAM_API_KEY_RECORDS=

# OIDC-only hosted setup. Replace the repository ID and workflow ref before enabling.
GITHUB_OIDC_ENABLED=false
GITHUB_OIDC_ISSUER=https://token.actions.githubusercontent.com
GITHUB_OIDC_AUDIENCE=diagram-gateway
GITHUB_OIDC_JWKS_URL=https://token.actions.githubusercontent.com/.well-known/jwks
GITHUB_OIDC_REPOSITORY_POLICIES=[{"repositoryId":"123456789","workflowRefs":["owner/repository/.github/workflows/diagram-check.yml@refs/*"],"events":{"pull_request":{"refs":["refs/pull/*"],"baseRefs":["main"]},"push":{"refs":["refs/heads/main"]},"workflow_dispatch":{"refs":["refs/heads/main"]}}}]
GITHUB_OIDC_CLOCK_TOLERANCE_SECONDS=30
GITHUB_OIDC_JWKS_CACHE_MAX_AGE_MS=600000
GITHUB_OIDC_JWKS_COOLDOWN_MS=30000
GITHUB_OIDC_JWKS_TIMEOUT_MS=5000
GATEWAY_PORT=9000
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RENDER_MAX_CONCURRENT=4
RENDER_MAX_QUEUE=20
MAX_OUTPUT_BYTES=10485760
CACHE_MAX_ENTRIES=500
CACHE_MAX_BYTES=268435456
CACHE_MAX_ITEM_BYTES=5242880
CACHE_TTL_MS=86400000
GATEWAY_PIDS_LIMIT=256
GATEWAY_MEMORY_LIMIT=512m
GATEWAY_CPU_LIMIT=1.0
KROKI_PIDS_LIMIT=256
KROKI_MEMORY_LIMIT=1g
KROKI_CPU_LIMIT=2.0
MERMAID_PIDS_LIMIT=256
MERMAID_MEMORY_LIMIT=1g
MERMAID_CPU_LIMIT=1.0

# Override these to test images built from your Kroki fork.
KROKI_IMAGE=yuzutech/kroki:0.31.1
MERMAID_IMAGE=yuzutech/kroki-mermaid:0.31.1
GATEWAY_IMAGE=diagram-as-code-gateway:local
