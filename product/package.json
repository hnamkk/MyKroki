{
  "name": "@diagram-as-code/product",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "gateway",
    "vscode-extension",
    "github-action"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run contract:check && npm run test:pilot",
    "test:server-bundle": "node --test ./scripts/create-server-bundle.test.mjs",
    "test:release-contract": "node --test ./scripts/validate-release-contract.test.mjs",
    "test:pilot": "node --test ./scripts/pilot-package-contract.test.mjs ./scripts/pilot-render.test.mjs ./scripts/pilot-output-verifier.test.mjs",
    "pretypecheck": "npm --workspace=@diagram-as-code/contracts run build && npm --workspace=@diagram-as-code/diagram-config run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "smoke": "node scripts/smoke-test.mjs",
    "test:renderers": "node scripts/renderer-acceptance-test.mjs",
    "test:isolation": "node scripts/engine-isolation-test.mjs",
    "test:recovery": "node scripts/dependency-recovery-test.mjs",
    "test:performance": "node scripts/performance-test.mjs",
    "test:soak": "node scripts/soak-test.mjs",
    "test:security": "node scripts/security-test.mjs",
    "test:container-policy": "node scripts/container-policy-test.mjs",
    "test:repeat": "node scripts/repeat-test.mjs",
    "prepilot:generate": "npm --workspace=@diagram-as-code/contracts run build && npm --workspace=@diagram-as-code/diagram-config run build",
    "pilot:generate": "node scripts/generate-pilot.mjs",
    "pilot:verify": "node scripts/verify-pilot-output.mjs",
    "test:vscode-gateway": "npm --workspace=diagram-as-code-vscode run test:gateway-smoke",
    "contract:check": "node scripts/verify-openapi.mjs",
    "key:generate": "node scripts/generate-api-key.mjs",
    "release:sbom": "node scripts/prepare-npm-sbom.mjs",
    "release:bundle": "node scripts/prepare-release.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "release:prepare": "npm audit && npm run typecheck && npm test && npm run test:server-bundle && npm run test:release-contract && npm run build && npm --workspace=diagram-as-code-vscode run package && npm run release:sbom && npm run release:bundle && npm run release:verify"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=24"
  }
}
